rules_version = '2';

// Regras de segurança do Storage — Atípicos.
// MVP: apenas usuários autenticados leem/escrevem fotos das crianças.
service firebase.storage {
  match /b/{bucket}/o {
    match /criancas/{criancaId}/{arquivo} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024  // até 5 MB
        && request.resource.contentType.matches('image/.*');
    }
    match /{caminho=**} {
      allow read, write: if false;
    }
  }
}
