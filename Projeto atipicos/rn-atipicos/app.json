{
  "expo": {
    "name": "Atípicos",
    "slug": "atipicos-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-512.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo-atipicos.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDFBF7"
    },
    "assetBundlePatterns": ["**/*"],
    "experiments": { "tsconfigPaths": true },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O Atípicos usa a localização para que os responsáveis acompanhem onde a criança está e recebam alertas de emergência (SOS)."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#EB5757"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "O Atípicos usa a localização para que os responsáveis acompanhem a criança e recebam alertas de SOS."
      }
    },
    "android": {
      "package": "com.atipicos.app",
      "versionCode": 1,
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-192.png",
        "backgroundColor": "#FDFBF7"
      }
    },
    "web": { "favicon": "./assets/logo-atipicos.png" }
  }
}
