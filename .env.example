# Variáveis de ambiente do Firebase (Expo lê automaticamente as EXPO_PUBLIC_*).
# 1. Copie este arquivo para `.env`
# 2. Preencha com os valores do seu projeto (Console Firebase → Configurações do projeto → Apps → SDK)
# 3. NUNCA versione o `.env` (já está no .gitignore)

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
