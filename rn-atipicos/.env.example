# Variáveis de ambiente do Firebase (Expo lê automaticamente as EXPO_PUBLIC_*).
# 1. Copie este arquivo para `.env`
# 2. Preencha com os valores do seu projeto (Console Firebase → Configurações do projeto → Apps → SDK)
# 3. NUNCA versione o `.env` (já está no .gitignore)

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# OPCIONAL — deixe vazio/ausente para ficar no plano GRATUITO (Spark).
# A foto da criança é salva como base64 no Firestore (grátis). Só defina como
# "true" se você optar pelo Firebase Storage real (exige plano Blaze, pago).
# EXPO_PUBLIC_FIREBASE_USE_STORAGE=false

# OPCIONAL — feed de notícias sobre TEA (tela do responsável).
# Crie uma chave grátis em https://newsapi.org e cole abaixo. Sem chave, o app
# mostra um conteúdo de exemplo (não quebra). Em RN a chamada funciona sem CORS.
# EXPO_PUBLIC_NEWSAPI_KEY=
