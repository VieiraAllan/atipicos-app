rules_version = '2';

// Regras de segurança do Firestore — Atípicos (RNF07, RNF08).
// Modelo: responsável ↔ criança ↔ terapeuta, com tarefas e localizações.
// Os documentos guardam os uids relacionados (responsavelUid, terapeutaId,
// contaUid) para permitir consultas e checagens de acesso simples.
service cloud.firestore {
  match /databases/{database}/documents {

    function logado() { return request.auth != null; }
    function eu() { return request.auth.uid; }

    // Perfis. Leitura liberada para usuários logados (necessário para listar
    // terapeutas e validar o perfil no login). O responsável cria o perfil da
    // criança ao cadastrá-la; cada um só edita/exclui o próprio.
    match /usuarios/{uid} {
      allow read: if logado();
      allow create: if logado();
      allow update, delete: if logado() && eu() == uid;
    }

    // Crianças — acessíveis pelo responsável, pelo terapeuta vinculado e pela
    // própria conta de login da criança.
    match /criancas/{id} {
      function envolvido(d) {
        return eu() == d.responsavelUid || eu() == d.terapeutaId || eu() == d.contaUid;
      }
      allow read: if logado() && envolvido(resource.data);
      allow create: if logado() && eu() == request.resource.data.responsavelUid;
      allow update, delete: if logado() && envolvido(resource.data);
    }

    // Tarefas — criadas pelo responsável; a criança pode concluir (update);
    // todos os envolvidos podem ler.
    match /tarefas/{id} {
      function envolvido(d) {
        return eu() == d.responsavelUid || eu() == d.terapeutaId || eu() == d.contaUid;
      }
      allow read: if logado() && envolvido(resource.data);
      allow create: if logado() && eu() == request.resource.data.responsavelUid;
      allow update: if logado() && envolvido(resource.data);
      allow delete: if logado() && eu() == resource.data.responsavelUid;
    }

    // Localizações — a criança grava a própria; o responsável grava a inicial;
    // responsável/terapeuta/criança podem ler.
    match /localizacoes/{criancaId} {
      allow read: if logado() && (
        eu() == resource.data.responsavelUid ||
        eu() == resource.data.terapeutaId ||
        eu() == resource.data.contaUid
      );
      allow write: if logado() && (
        eu() == request.resource.data.responsavelUid ||
        eu() == request.resource.data.contaUid
      );
    }

    // Alertas de emergência (SOS) — a criança cria; responsável e terapeuta leem.
    // Guarda responsavelUid/terapeutaId denormalizados para a consulta do histórico.
    match /alertas/{id} {
      allow read: if logado() && (
        eu() == resource.data.responsavelUid ||
        eu() == resource.data.terapeutaId
      );
      allow create: if logado();
    }

    // Bloqueia qualquer outro caminho por padrão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
